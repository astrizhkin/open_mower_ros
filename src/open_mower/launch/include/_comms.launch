<!--
    This launch file starts all communication needed in order to control and localize the bot.
    I.e. the raw data comms to the Low Level Board, the GPS, etc.
-->
<launch>
    <!-- TODO: Add parameter for simulation -->

    <node pkg="mower_comms" type="mower_comms" name="mower_comms" unless="$(optenv OM_NO_COMMS False)" output="screen">
        <rosparam unless="$(eval env('OM_EXT_COMMS_PARAMS')!='')" file="$(find open_mower)/params/hardware_specific/$(env OM_BODY)/comms_params.yaml"/>
        <rosparam if="$(eval env('OM_EXT_COMMS_PARAMS')!='')" file="$(env PARAMS_PATH)/$(env OM_EXT_COMMS_PARAMS)"/>
        <param name="wheel_radius_m" value="$(env OM_WHEEL_RADIUS_M)"/>
        <param name="wheel_separation_m" value="$(env OM_WHEEL_SEPARATION_M)"/>
        <!-- base_link right hand rule -->
        <!-- param name="imu_accel_axes" value="+y+x-z" /-->
        <!-- param name="imu_gyro_axes" value="+y-x-z" /-->
        <param name="mower_esc_enabled" value="$(env OM_ENABLE_MOWER)"/>
    </node>

    <node pkg="mower_comms" type="antislip" name="antislip" output="screen">
      <remap from="~imu_in" to="/imu/data_raw"/>
      <remap from="~twist_in" to="/mower/measured_vel"/>
      <!--remap from="~odom3d_in" to="/xbot_positioning/odom_3d_out"/-->
    </node>
    
    <include file="$(find open_mower)/launch/include/_$(env OM_ESC_DRIVE_TYPE).launch" />

    <include file="$(find open_mower)/launch/include/_gps.launch" unless="$(optenv OM_NO_GPS False)"/>

</launch>
