<launch>
    <rosparam file="$(find open_mower)/params/hardware_specific/$(env OM_MOWER)/odrive.yaml" command="load" subst_value="true"/>
    <!--rosparam file="$(env PARAMS_PATH)/odrive.yaml" command="load" subst_value="true"/-->

    <!--node name="odrive_can" pkg="odrive_can" type="odrive_can_node" output="screen"
        respawn="true" respawn_delay="2.0"/-->

    <!-- CAN communication + hardware interface + control loop -->
    <node name="odrive_driver" pkg="odrive_ros_control" type="odrive_ros_control_node"
        respawn="true" output="screen"/>

    <remap from="/front_velocity_controller/cmd_vel" to="/cmd_vel_safe"/>
    <remap from="/rear_velocity_controller/cmd_vel" to="/cmd_vel_safe"/>

    <!-- Controllers -->
    <node name="controller_spawner" pkg="controller_manager" type="spawner"
        respawn="false" output="screen"
        args="front_joint_publisher rear_joint_publisher
              front_velocity_controller rear_velocity_controller"/>
</launch>